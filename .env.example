# AEC Smart Result Access System — Environment Variables
# Copy this file to .env and adjust values as needed

# Server port
PORT=3000

# Cache TTL in milliseconds (default: 1 hour = 3600000)
CACHE_TTL_MS=3600000

# Maximum number of cached entries before LRU eviction
MAX_CACHE_SIZE=1000

# Rate limiting: requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Portal fetch cooldown per HTNo (default: 5 minutes)
PORTAL_FETCH_COOLDOWN_MS=300000
